# Python bytecode and cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.env/
.venv/

# Trained model weights
# These are large binary files that should not be committed to version control
# Store them on Google Drive or use Git LFS if you need to version them
*.h5
*.hdf5
*.pb
*.pt
*.pth
*.ckpt
*.weights

# Training history and saved states
*.pkl
*.pickle

# Dataset files
# Raw and cached datasets are large and reproducibly downloadable
*.npz
*.npy
datasets/

# TensorFlow and Keras autogenerated files
*.tfevents.*
logs/
runs/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Jupyter runtime files
*.ipynb_checkpoints

# CSV training logs (optional: remove this line if you want to commit training logs)
history/
*.csv

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Coverage and test output
.coverage
htmlcov/
.pytest_cache/

# Build artifacts
dist/
build/
*.egg-info/

# Colab-specific output that should not be committed
sample_data/
